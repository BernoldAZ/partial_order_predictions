# =============================================================================
# SuffixTransformerNetwork / BEST – JupyterLab container
# CUDA 11.8 + cuDNN 8 + Python 3.11
# =============================================================================
# Build:
#   docker build -t ppm-sutran-best .
#
# Run (GPU, mount current directory so edits are live):
#   docker run -it --rm -p 127.0.0.1:8887:8887 -v $(pwd):/app --gpus all ppm-sutran-best
#
# Then open http://localhost:8887/lab in your browser.
# =============================================================================

# ── Base image ────────────────────────────────────────────────────────────────
FROM nvidia/cuda:11.8.0-cudnn8-devel-ubuntu22.04

# ── Environment ───────────────────────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    # Make every module in /app importable without sys.path manipulation
    PYTHONPATH=/app

# ── System packages ───────────────────────────────────────────────────────────
# graphviz      – required by pm4py for process-map rendering
# libgomp1      – OpenMP runtime used by NumPy / SciKit-Learn
# build-essential, python3.11-dev – needed to compile any C-extension wheels
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-dev \
    python3.11-venv \
    python3-pip \
    build-essential \
    curl \
    git \
    wget \
    ca-certificates \
    graphviz \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# ── Python 3.11 as default + pip bootstrap ────────────────────────────────────
# Ubuntu 22.04 ships Python 3.10 as the system default; override it.
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python  python  /usr/bin/python3.11 1

# Upgrade pip / setuptools / wheel for Python 3.11.
# python3-pip (installed above via apt) already provides pip; we just upgrade it.
# ensurepip is disabled on Debian/Ubuntu system Python, so we skip it entirely.
RUN python3 -m pip install --upgrade pip setuptools wheel

# ── Python dependencies ───────────────────────────────────────────────────────
# Copy requirements first so Docker can cache this layer independently of code.
WORKDIR /app
COPY requirements.txt .
RUN python3 -m pip install -r requirements.txt

# ── Project source code ───────────────────────────────────────────────────────
# Baked into the image for standalone operation.
# When running with  -v $(pwd):/app  the live directory takes precedence.
COPY . .

# ── Jupyter kernel registration ───────────────────────────────────────────────
RUN python3 -m ipykernel install --sys-prefix --name python3 --display-name "Python 3.11 (PPM)"

# ── Expose JupyterLab port ────────────────────────────────────────────────────
EXPOSE 8887

# ── Default command: start JupyterLab ─────────────────────────────────────────
# --ServerApp.token / --ServerApp.password: disable authentication for local use
# (the port is bound to 127.0.0.1 in the run command above, so it is not
#  exposed to the network)
CMD ["jupyter", "lab", \
     "--ip=0.0.0.0", \
     "--port=8887", \
     "--allow-root", \
     "--no-browser", \
     "--ServerApp.token=''", \
     "--ServerApp.password=''"]
